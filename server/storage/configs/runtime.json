{
  "runtime": {
    "mode": "backtest",
    "logLevel": "info"
  },
  "market": {
    "timezone": "America/New_York",
    "sessionMode": "regular",
    "openMinutes": 570,
    "closeMinutes": 960,
    "preCloseMinutes": 10,
    "noTradeOpenMinutes": 10
  },
  "alpaca": {
    "enabled": true,
    "paper": true,
    "feed": "iex",
    "adjustment": "raw",
    "maxRetries": 4,
    "retryBaseDelayMs": 750,
    "retryMaxDelayMs": 5000
  },
  "llm": {
    "enabled": false,
    "provider": "ollama",
    "model": "llama3.1:8b",
    "baseUrl": "http://127.0.0.1:11434",
    "temperature": 0.1,
    "timeoutMs": 30000
  },
  "news": {
    "enabled": true,
    "userAgent": "baptisto-trading-v3/0.1 (+local research runner)",
    "timeoutMs": 10000,
    "cacheTtlMs": 900000,
    "maxItemsPerFeed": 8,
    "feeds": [
      {
        "id": "sec_press_releases",
        "name": "SEC Press Releases",
        "url": "https://www.sec.gov/rss/pressrelease.xml"
      },
      {
        "id": "sec_news",
        "name": "SEC News",
        "url": "https://www.sec.gov/rss/news/press.xml"
      },
      {
        "id": "fed_press_all",
        "name": "Federal Reserve Press Releases",
        "url": "https://www.federalreserve.gov/feeds/press_all.xml"
      },
      {
        "id": "fed_monetary",
        "name": "Federal Reserve Monetary Policy",
        "url": "https://www.federalreserve.gov/feeds/press_monetary.xml"
      }
    ]
  },
  "reports": {
    "daily": {
      "enabled": true,
      "outputSubdir": "daily",
      "watchlistSymbols": [
        "AAPL",
        "AMZN",
        "META",
        "GOOGL",
        "AMD",
        "NVDA",
        "SPY",
        "QQQ"
      ],
      "maxNewsItemsPerFeed": 5,
      "includeLlmAnalysis": true,
      "llmTimeoutMs": 120000
    }
  },
  "execution": {
    "dryRun": true
  },
  "telemetry": {
    "console": {
      "enabled": true,
      "colors": true
    }
  },
  "symbols": {
    "default": {
      "enabled": true,
      "strategy": "llm_long_v1",
      "strategyProfile": "single_stock",
      "timeframes": [
        "1m",
        "2m",
        "5m",
        "10m",
        "15m",
        "30m",
        "1h",
        "4h",
        "1d"
      ],
      "evaluationTimeframes": [
        "10s",
        "30s",
        "1m",
        "2m",
        "5m",
        "10m"
      ],
      "brokerProtection": {
        "enabled": true,
